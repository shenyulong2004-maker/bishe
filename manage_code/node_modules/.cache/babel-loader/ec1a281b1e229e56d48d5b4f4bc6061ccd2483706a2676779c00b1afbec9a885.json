uter'\r\n\timport {\r\n\t\tElMessageBox\r\n\t} from 'element-plus'\r\n\tconst context = getCurrentInstance()?.appContext.config.globalProperties;\r\n\timport formModel from './formModel.vue'\r\n\t\r\n\t//тЪ║уАђС┐АТЂ»\r\n\tconst tableName = 'exampaper'\r\n\tconst formName = 'У»ЋтЇиу«Ауљє'\r\n\tconst route = useRoute()\r\n\t//тЪ║уАђС┐АТЂ»\r\n\tonMounted(()=>{\r\n\t})\r\n\t//тѕЌУАеТЋ░ТЇ«\r\n\tconst list = ref(null)\r\n\tconst table = ref(null)\r\n\tconst listQuery = ref({\r\n\t\tpage: 1,\r\n\t\tlimit: 20,\r\n\t\tsort: 'id',\r\n\t\torder: 'desc'\r\n\t})\r\n\tconst searchQuery = ref({})\r\n\tconst selRows = ref([])\r\n\tconst listLoading = ref(false)\r\n\tconst listChange = (row) =>{\r\n\t\tnextTick(()=>{\r\n\t\t\ttable.value.clearSelection()\r\n\t\t\ttable.value.toggleRowSelection(row)\r\n\t\t})\r\n\t}\r\n\t//тѕЌУАе\r\n\tconst getList = () => {\r\n\t\tlistLoading.value = true\r\n\t\tlet params = JSON.parse(JSON.stringify(listQuery.value))\r\n\t\tparams['sort'] = 'id'\r\n\t\tparams['order'] = 'desc'\r\n\t\tif(searchQuery.value.name&&searchQuery.value.name!=''){\r\n\t\t\tparams['name'] = '%' + searchQuery.value.name + '%'\r\n\t\t}\r\n\t\tcontext?.$http({\r\n\t\t\turl: `${tableName}/page`,\r\n\t\t\tmethod: 'get',\r\n\t\t\tparams: params\r\n\t\t}).then(res => {\r\n\t\t\tlistLoading.value = false\r\n\t\t\tlist.value = res.data.data.list\r\n\t\t\ttotal.value = Number(res.data.data.total)\r\n\t\t})\r\n\t}\r\n\t//тѕа\r\n\tconst delClick = (id) => {\r\n\t\tlet ids = ref([])\r\n\t\tif (id) {\r\n\t\t\tids.value = [id]\r\n\t\t} else {\r\n\t\t\tif (selRows.value.length) {\r\n\t\t\t\tfor (let x in selRows.value) {\r\n\t\t\t\t\tids.value.push(selRows.value[x].id)\r\n\t\t\t\t}\r\n\t\t\t} else {\r\n\t\t\t\treturn false\r\n\t\t\t}\r\n\t\t}\r\n\t\tElMessageBox.confirm(`Тў»тљдтѕажЎцжђЅСИГ${formName}`, 'ТЈљуц║', {\r\n\t\t\tconfirmButtonText: 'Тў»',\r\n\t\t\tcancelButtonText: 'тљд',\r\n\t\t\ttype: 'warning',\r\n\t\t}).then(() => {\r\n\t\t\tcontext?.$http({\r\n\t\t\t\turl: `${tableName}/delete`,\r\n\t\t\t\tmethod: 'post',\r\n\t\t\t\tdata: ids.value\r\n\t\t\t}).then(res => {\r\n\t\t\t\tcontext?.$toolUtil.message('тѕажЎцТѕљтіЪ', 'success',()=>{\r\n\t\t\t\t\tgetList()\r\n\t\t\t\t})\r\n\t\t\t})\r\n\t\t})\r\n\t}\r\n\t//тцџжђЅ\r\n\tconst handleSelectionChange = (e) => {\r\n\t\tselRows.value = e\r\n\t}\r\n\t//тѕЌУАеТЋ░ТЇ«\r\n\t//тѕєжАх\r\n\tconst total = ref(0)\r\n\tconst layouts = ref([\"prev\",\"pager\",\"next\"])\r\n\tconst sizeChange = (size) => {\r\n\t\tlistQuery.value.limit = size\r\n\t\tgetList()\r\n\t}\r\n\tconst currentChange = (page) => {\r\n\t\tlistQuery.value.page = page\r\n\t\tgetList()\r\n\t}\r\n\tconst prevClick = () => {\r\n\t\tlistQuery.value.page = listQuery.value.page - 1\r\n\t\tgetList()\r\n\t}\r\n\tconst nextClick = () => {\r\n\t\tlistQuery.value.page = listQuery.value.page + 1\r\n\t\tgetList()\r\n\t}\r\n\t//тѕєжАх\r\n\t//ТЮЃжЎљжфїУ»Ђ\r\n\tconst btnAuth = (e,a)=>{\r\n\t\treturn context?.$toolUtil.isAuth(e,a)\r\n\t}\r\n\t//Тљюу┤б\r\n\tconst searchClick = () => {\r\n\t\tlistQuery.value.page = 1\r\n\t\tgetList()\r\n\t}\r\n\t//УАетЇЋ\r\n\tconst formRef = ref(null)\r\n\tconst formModelChange=()=>{\r\n\t\tsearchClick()\r\n\t}\r\n\tconst addClick = ()=>{\r\n\t\tformRef.value.init()\r\n\t}\r\n\tconst editClick = ()=>{\r\n\t\tif(selRows.value.length){\r\n\t\t\tformRef.value.init(selRows.value[0].id,'edit')\r\n\t\t}\r\n\t}\r\n\t\r\n\tconst infoClick = (id=null)=>{\r\n\t\tif(id){\r\n\t\t\tformRef.value.init(id,'info')\r\n\t\t}\r\n\t\telse if(selRows.value.length){\r\n\t\t\tformRef.value.init(selRows.value[0].id,'info')\r\n\t\t}\r\n\t}\r\n\t// УАетЇЋ\r\n\t// жбёУДѕТќЄС╗Х\r\n\tconst preClick = (file) =>{\r\n\t\tif(!file){\r\n\t\t\tcontext?.$toolUtil.message('ТќЄС╗ХСИЇтГўтюе','error')\r\n\t\t}\r\n\t\twindow.open(context?.$config.url + file)\r\n\t\t// const a = document.createElement('a');\r\n\t\t// a.style.display = 'none';\r\n\t\t// a.setAttribute('target', '_blank');\r\n\t\t// file && a.setAttribute('download', file);\r\n\t\t// a.href = context?.$config.url + file;\r\n\t\t// document.body.appendChild(a);\r\n\t\t// a.click();\r\n\t\t// document.body.removeChild(a);\r\n\t}\r\n\t// СИІУййТќЄС╗Х\r\n\tconst download = (file) => {\r\n\t\tif(!file){\r\n\t\t\tcontext?.$toolUtil.message('ТќЄС╗ХСИЇтГўтюе','error')\r\n\t\t}\r\n\t\tlet arr = file.replace(new RegExp('file/', \"g\"), \"\")\r\n\t\taxios.get((location.href.split(context?.$config.name).length>1 ? location.href.split(context?.$config.name)[0] :'') + context?.$config.name + '/file/download?fileName=' + arr, {\r\n\t\t\theaders: {\r\n\t\t\t\ttoken: context?.$toolUtil.storageGet('Token')\r\n\t\t\t},\r\n\t\t\tresponseType: \"blob\"\r\n\t\t}).then(({\r\n\t\t\tdata\r\n\t\t}) => {\r\n\t\t\tconst binaryData = [];\r\n\t\t\tbinaryData.push(data);\r\n\t\t\tconst objectUrl = window.URL.createObjectURL(new Blob(binaryData, {\r\n\t\t\t\ttype: 'application/pdf;chartset=UTF-8'\r\n\t\t\t}))\r\n\t\t\tconst a = document.createElement('a')\r\n\t\t\ta.href = objectUrl\r\n\t\t\ta.download = arr\r\n\t\t\t// a.click()\r\n\t\t\t// СИІжЮбУ┐ЎСИфтєЎТ│ЋтЁ╝т«╣уЂФуІљ\r\n\t\t\ta.dispatchEvent(new MouseEvent('click', {\r\n\t\t\t\tbubbles: true,\r\n\t\t\t\tcancelable: true,\r\n\t\t\t\tview: window\r\n\t\t\t}))\r\n\t\t\twindow.URL.revokeObjectURL(data)\r\n\t\t})\r\n\t}\r\n\r\n\tconst exampaperStatusFormatter =(row, column)=> {\r\n\t  var temp = ''\r\n\t  // тцёуљєжђ╗УЙЉ С┐ЮтГўТјЦтЈБ ТЋ░ТЇ«№╝їУ┐ЏУАїтї╣жЁЇ name\r\n\t  switch (row.status-0) {\r\n\t    case 0:\r\n\t      temp = 'удЂуће'\r\n\t      break\r\n\t    case 1:\r\n\t      temp = 'тљ»уће'\r\n\t      break\r\n\t  }\r\n\t  return temp\r\n\t}\r\n\r\n\t//тѕЮтДІтїќ\r\n\tconst init = () => {\r\n\t\tgetList()\r\n\t}\r\n\tinit()\r\n</script>\r\n<style lang=\"scss\" scoped>\r\n\t\r\n\t// ТЊЇСйюуЏњтГљ\r\n\t.list_search_view {\r\n\t\tmargin: 0 0 20px;\r\n\t\tdisplay: flex;\r\n\t\tjustify-content: space-between;\r\n\t\tflex-wrap: wrap;\r\n\t\t// Тљюу┤буЏњтГљ\r\n\t\t.search_form {\r\n\t\t\tdisplay: flex;\r\n\t\t\talign-items: center;\r\n\t\t\torder: 2;\r\n\
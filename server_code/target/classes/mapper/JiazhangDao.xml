<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cl.dao.JiazhangDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.cl.entity.JiazhangEntity" id="jiazhangMap">
        <result property="jiazhangzhanghao" column="jiazhangzhanghao"/>
        <result property="mima" column="mima"/>
        <result property="jiazhangxingming" column="jiazhangxingming"/>
        <result property="touxiang" column="touxiang"/>
        <result property="xingbie" column="xingbie"/>
        <result property="shoujihaoma" column="shoujihaoma"/>
        <result property="xuehao" column="xuehao"/>
        <result property="xingming" column="xingming"/>
    </resultMap>

    <select id="selectListView"
		resultType="com.cl.entity.view.JiazhangView" >

		SELECT  jiazhang.* FROM jiazhang  jiazhang 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.cl.entity.view.JiazhangView" >
		SELECT * FROM jiazhang  jiazhang <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectGroupBy"
		resultType="com.cl.entity.view.JiazhangView" >
		select userid,username,paperid,papername,sum(myscore) myscore,ROUND(sum(case when myscore>0 then 1 else 0 end)/(sum(1)),2) accuracy from examrecord     
        <where> 1=1 ${ew.sqlSegment}</where>
        group by userid,username,paperid,papername  
	</select>

</mapper>
